# Backend environment variables for Render or local development
PORT=3001
DATABASE_URL=postgresql://user:password@host:5432/database
# One frontend origin allowed for production
CLIENT_ORIGIN=https://your-frontend-domain.com
# Or provide multiple allowed origins for development and production:
# CLIENT_ORIGINS=http://localhost:3000,https://your-frontend-domain.com
SESSION_SECRET=your-secure-session-secret
NODE_ENV=production
# Cloudinary credentials for image uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Optional admin seed credentials used by backend/seed.js
ADMIN_EMAIL=business@gmail.com
ADMIN_PASSWORD=123456